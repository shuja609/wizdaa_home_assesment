# Server Configuration
PORT=3000

# Database Configuration
# Currently supporting SQLite for assessment; production would use Postgres
DB_FILE=database.sqlite

# Security & Authentication
# Shared secret for batch ingestion authentication (HCM -> Microservice)
HCM_SHARED_SECRET=test-secret
# JWT signing key for client-facing API access
JWT_SECRET=wizdaa_internal_security_key_v1

# External HCM Integration
# Points to the Mock HCM server (mock-hcm/server.js) for testing
HCM_API_URL=http://localhost:3001

# Business Logic Constraints
# Recovery window for APPROVED request cancellation (in hours)
GRACE_WINDOW_HOURS=24
# Minimum minutes between forced balance synchronization attempts
HCM_SYNC_THRESHOLD_MIN=5

# Rate Limiting Logic (Implemented in AppModule)
GLOBAL_RATE_LIMIT=100
EMPLOYEE_RATE_LIMIT=10
RATE_LIMIT_TTL=60000

# Observability
# drift check frequency (Standard Cron syntax)
DRIFT_CHECK_CRON="0 * * * *"
